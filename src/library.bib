@article{ramirezmedinaSystematicReviewMachine2025,
  title = {A Systematic Review of Machine Learning Applications in Predicting Opioid Associated Adverse Events},
  author = {Ram{\'i}rez Medina, Carlos R. and {Benitez-Aurioles}, Jose and Jenkins, David A. and Jani, Meghna},
