[32m+[m[32m@article{gabrielReviewLeveragingArtificial2025,[m
[32m+[m[32m  title = {A {{Review}} of {{Leveraging Artificial Intelligence}} to {{Predict Persistent Postoperative Opioid Use}} and {{Opioid Use Disorder}} and Its {{Ethical Considerations}}},[m
[32m+[m[32m  author = {Gabriel, Rodney A. and Park, Brian H. and Hsu, Chun-Nan and Macias, Alvaro A.},[m
[32m+[m[32m  year = 2025,[m
[32m+[m[32m  month = jan,[m
[32m+[m[32m  journal = {Current Pain and Headache Reports},[m
[32m+[m[32m  volume = {29},[m
[32m+[m[32m  number = {1},[m
[32m+[m[32m  pages = {30},[m
[32m+[m[32m  issn = {1534-3081},[m
[32m+[m[32m  doi = {10.1007/s11916-024-01319-2},[m
[32m+[m[32m  abstract = {PURPOSE OF REVIEW: Artificial intelligence (AI) offers a new frontier for aiding in the management of both acute and chronic pain, which may potentially transform opioid prescribing practices and addiction prevention strategies. In this review paper, not only do we discuss some of the current literature around predicting various opioid-related outcomes, but we also briefly point out the next steps to improve trustworthiness of these AI models prior to real-time use in clinical workflow. RECENT FINDINGS: Machine learning-based predictive models for identifying risk for persistent postoperative opioid use have been reported for spine surgery, knee arthroplasty, hip arthroplasty, arthroscopic joint surgery, outpatient surgery, and mixed surgical populations. Several machine learning-based models have been described to predict an individual's propensity for opioid use disorder and opioid overdose. Natural language processing and large language model approaches have been described to detect opioid use disorder and persistent postsurgical opioid use from clinical notes. AI holds significant promise in enhancing the management of acute and chronic opioids, which may offer tools to help optimize dosing, predict addiction risks, and personalize pain management strategies. By harnessing the power of AI, healthcare providers can potentially improve patient outcomes, reduce the burden of opioid addiction, and contribute to solving the opioid crisis.},[m
[32m+[m[32m  langid = {english},[m
[32m+[m[32m  pmcid = {PMC11758157},[m
[32m+[m[32m  pmid = {39847176},[m
[32m+[m[32m  keywords = {Analgesics Opioid,Artificial intelligence,Artificial Intelligence,Humans,Machine learning,Machine Learning,Opioid use disorder,Opioid-Related Disorders,Persistent opioid use,Postoperative Pain,Surgery}[m
[32m+[m[32m}[m
