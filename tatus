[32m+[m[32m  shorttitle = {Opioid {{Crisis}}},[m
[32m+[m[32m  author = {Dasgupta, Nabarun and Beletsky, Leo and Ciccarone, Daniel},[m
[32m+[m[32m  year = 2018,[m
[32m+[m[32m  month = feb,[m
[32m+[m[32m  journal = {American Journal of Public Health},[m
[32m+[m[32m  volume = {108},[m
[32m+[m[32m  number = {2},[m
[32m+[m[32m  pages = {182--186},[m
