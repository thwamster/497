[32m+[m[32m  author = {Kim, Ji-Woo and Kim, Chungsoo and Kim, Kyoung-Hoon and Lee, Yujin and Yu, Dong Han and Yun, Jeongwon and Baek, Hyeran and Park, Rae Woong and You, Seng Chan},[m
