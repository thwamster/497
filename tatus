[32m+[m[32m@article{murphyCostOpioidUse2020,[m
[32m+[m[32m  title = {The {{Cost}} of {{Opioid Use Disorder}} and the {{Value}} of {{Aversion}}},[m
[32m+[m[32m  author = {Murphy, Sean M.},[m
[32m+[m[32m  year = 2020,[m
[32m+[m[32m  month = dec,[m
[32m+[m[32m  journal = {Drug and alcohol dependence},[m
[32m+[m[32m  volume = {217},[m
