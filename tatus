[32m+[m[32m@article{liMultitaskLearningDynamic2023,[m
[32m+[m[32m  title = {Multi-Task Learning with Dynamic Re-Weighting to Achieve Fairness in Healthcare Predictive Modeling},[m
[32m+[m[32m  author = {Li, Can and Ding, Sirui and Zou, Na and Hu, Xia and Jiang, Xiaoqian and Zhang, Kai},[m
[32m+[m[32m  year = 2023,[m
